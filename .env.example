# invest-alert-bot — Author: Shijie Zheng (Kerry Zheng)
# https://github.com/Formyselfonly/invest-alert-bot
# Telegram Bot credentials — create via @BotFather (see readme.md)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: override config file path
# CONFIG_PATH=config.yaml

# ── AI 分析（TradingAgents，可选）────────────────────────────
# 安装依赖：uv sync --extra analysis
# 不安装时 Bot 监控/告警照常运行，只是不会跑 AI 分析
ANALYSIS_ENABLED=false

# deepseek（推荐，便宜）| openai
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 若使用 OpenAI，改为：
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here

ANALYSIS_DEEP_MODEL=deepseek-chat
ANALYSIS_QUICK_MODEL=deepseek-chat
ANALYSIS_MAX_DEBATE_ROUNDS=1
# 分析师：market | social | news | fundamentals（逗号分隔）
# 默认去掉 social（Reddit 常 403，且与 news 重叠）
ANALYSIS_ANALYSTS=market,news,fundamentals
# TradingAgents 多轮 LLM 通常需 5～20+ 分钟，默认 30 分钟上限
ANALYSIS_TIMEOUT_SECONDS=1800
ANALYSIS_TEMPERATURE=0.2
ANALYSIS_REPORTS_DIR=reports

# 可选：LangSmith 追踪
# LANGCHAIN_API_KEY=

# 可选：Alpha Vantage（TradingAgents 部分数据源）
# ALPHA_VANTAGE_API_KEY=
